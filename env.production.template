# Copy this to .env on the VPS and fill in real values.
# Never commit the filled-in version.

PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=


# Email Configuration
ADMIN_EMAIL=
SMTP_FROM_NAME="Spiritans Sounds"
SMTP_FROM_EMAIL=

# Resend (newsletter campaigns)
RESEND_API_KEY=


# New migration env
# APPLICATION
APP_URL=https://www.spiritanssound.com


# S3 STORAGE (You can still point this to your R2/Spaces dev bucket)
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# CLOUDFLARE R2 CONFIGURATION
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# R2 Endpoint URL format (Found on your R2 dashboard)
S3_ENDPOINT=

# Public delivery URL (Your custom domain or the public R2 dev domain)
NEXT_PUBLIC_ASSET_URL=

TOKEN_VALUE=

NODE_ENV=production

# App
PAYLOAD_SECRET=
NEXT_PUBLIC_SERVER_URL=https://yourdomain.com
PORT=3000

# Database (matches docker-compose.yml)
POSTGRES_DB=spiritans_prod
POSTGRES_USER=payload
POSTGRES_PASSWORD=
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1:5432/${POSTGRES_DB}

# Cloudflare R2
S3_BUCKET=
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Backup script (same as R2 above, duplicated for clarity)
BACKUP_RETAIN_COUNT=14
BACKUP_PREFIX=db-backups
